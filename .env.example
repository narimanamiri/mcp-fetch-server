FETCH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Optional comma-separated domain allowlist. Empty means all public hosts are allowed.
FETCH_ALLOWED_DOMAINS=

# Fetch limits
FETCH_MAX_RESPONSE_BYTES=5242880
FETCH_REQUEST_TIMEOUT_SECONDS=30
FETCH_MAX_REDIRECTS=5
FETCH_REQUEST_RETRIES=3
FETCH_RETRY_BACKOFF_SECONDS=0.5
FETCH_DEFAULT_MAX_LENGTH=5000

# Fetch history / cache (backs the history:// and fetch-cache:// resources)
FETCH_MAX_HISTORY_ENTRIES=50
FETCH_MAX_CACHE_BYTES=2000000

# batch_fetch tool
FETCH_MAX_BATCH_URLS=10
FETCH_MAX_BATCH_CONCURRENCY=5

# web_search tool (DuckDuckGo HTML endpoint, no API key required)
FETCH_SEARCH_MAX_RESULTS=5
FETCH_SEARCH_TIMEOUT_SECONDS=15

# Optional SearXNG fallback for web_search (used only if DuckDuckGo fails).
# Run `docker compose up -d` (see docker-compose.yml) to start one locally.
# Set to empty to disable the fallback entirely.
FETCH_SEARXNG_URL=http://localhost:8080
FETCH_SEARXNG_TIMEOUT_SECONDS=10

# Local file tools (read_file/write_file/list_dir). Empty = disabled.
# Set this to a directory you want the server allowed to read/write in.
FETCH_LOCAL_FILES_ROOT=
FETCH_MAX_FILE_READ_BYTES=2000000
FETCH_MAX_FILE_WRITE_BYTES=2000000

# Required for streamable-http transport
MCP_AUTH_TOKEN=change-me-to-a-long-random-token

# HTTP rate limiting (requests per minute per token/IP)
MCP_RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
