# Docker Compose environment template.
# Copy to .env before starting the stack:
#   Linux/macOS: cp .env.docker.example .env
#   Windows:     copy .env.docker.example .env
#
# Then run:
#   docker compose up -d --build

# --- Required ---
MCP_AUTH_TOKEN=change-me-to-a-long-random-token

# Project name for Docker Compose (optional; avoids generic folder-based names)
COMPOSE_PROJECT_NAME=mcp-fetch-stack

# --- Published ports (host:container) ---
MCP_HTTP_PORT=8000
SEARXNG_HTTP_PORT=8080

# --- MCP fetch server ---
FETCH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
FETCH_ALLOWED_DOMAINS=
FETCH_MAX_RESPONSE_BYTES=5242880
FETCH_REQUEST_TIMEOUT_SECONDS=30
FETCH_MAX_REDIRECTS=5
FETCH_REQUEST_RETRIES=3
FETCH_RETRY_BACKOFF_SECONDS=0.5
FETCH_DEFAULT_MAX_LENGTH=5000
FETCH_MAX_HISTORY_ENTRIES=50
FETCH_MAX_CACHE_BYTES=2000000
FETCH_MAX_BATCH_URLS=10
FETCH_MAX_BATCH_CONCURRENCY=5
FETCH_SEARCH_MAX_RESULTS=5
FETCH_SEARCH_TIMEOUT_SECONDS=15

# Inside Docker the MCP container reaches SearXNG by service name (set in compose).
# Do not use localhost here — that would point at the MCP container itself.
FETCH_SEARXNG_URL=http://searxng:8080
FETCH_SEARXNG_TIMEOUT_SECONDS=10

# Local file tools: ./workspace on the host is mounted at /workspace in the container.
FETCH_LOCAL_FILES_ROOT=/workspace
FETCH_MAX_FILE_READ_BYTES=2000000
FETCH_MAX_FILE_WRITE_BYTES=2000000

# Admin GUI is served on the MCP HTTP port at /admin (streamable-http mode).
FETCH_ADMIN_ENABLED=true
FETCH_ADMIN_HOST=0.0.0.0
FETCH_ADMIN_PORT=8001

MCP_RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
